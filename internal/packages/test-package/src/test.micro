/*
    adds two numbers together (a, b)
*/
fn add(a, b) {
    return a + b;
}

/*
    2d point struct
*/
struct Point {
    x: i64;
    y: i64;
}

export fn main() {

    let arr = [1, 2, 3, 4, 5];

    let p: ptr = alloc_struct(Point);

    p.x = 10;
    p.y = 20;

    let temp = arr[1];
    let arr[0] = arr[4];
    let arr[4] = temp;


    let z = add(10, 5);

    return p.x + p.y + z;
}