/*
    adds two numbers together (a, b)
*/
fn add(a, b) {
    return a + b;
}

/*
    multiplies via repeated addition
*/
fn mul(a, b) {
    let result = 0;
    let i = 0;

    loop {
        if (i == b) {
            break;
        }

        result = result + a;
        i = i + 1;
    }

    return result;
}

/*
    sum an array of size n
*/
fn sum_array(ptr, n) {
    let i = 0;
    let total = 0;

    loop {
        if (i == n) {
            break;
        }

        total = total + ptr[i];
        i = i + 1;
    }

    return total;
}

/*
    2d point struct
*/
struct Point {
    x: i64;
    y: i64;
}

export fn main() {

    // 
    // ARRAY TESTING
    // 
    //let arr = [1, 2, 3, 4, 5];

    // swap arr[0] and arr[4]
    //let temp = arr[0];
    //arr[0] = arr[4];
    //arr[4] = temp;

    // 
    // STRUCT TESTING
    // 
    let p: ptr = alloc_struct(Point);

    p.x = 10;
    p.y = 20;

    // modify using function
    p.y = add(p.y, 5);   // 25

    // 
    // FUNCTION TESTING
    // 
    let z = add(10, 5);        // 15
    let m = mul(3, 4);         // 12

    // 
    // LOOP + CONDITIONAL TEST
    // 
    let counter = 0;
    let acc = 0;

    loop {
        if (counter == 10) {
            break;
        }

        if (counter == 5) {
            counter = counter + 1;
            continue;
        }

        acc = acc + counter;
        counter = counter + 1;
    }

    // acc = sum of 0..9 excluding 5 = 40

    // 
    // MEMORY TEST (peek/poke)
    // 
    let addr = 100;

    poke(addr, 42);
    let memval = peek(addr);   // 42

    // 
    // ARRAY FUNCTION TEST
    // 
    let total = sum_array(arr, 5);

    // 
    // FINAL RESULT
    // 
    return p.x        // 10
         + p.y        // 25
         + z          // 15
         + m          // 12
         + acc        // 40
         + memval     // 42
         + total;     // (5 + 2 + 3 + 4 + 1) = 15

    // expected output: 159
}