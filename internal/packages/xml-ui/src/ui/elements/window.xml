<?xml version='1.0' encoding='utf-8'?>
<Window width="default" height="default">
    <HEADER>
        <Import source="$package/src/ui/elements/generic.xml"/>
        <Import source="$package/src/ui/elements/specific.xml"/>
    </HEADER>
    <Frame positioning="grid">
        <Variable name="x" value="margin" />
        <Variable name="y" value="margin" />
        <Rect style="outline" x="var:x" y="var:y" width="100" height="100" color="0x666666" />
        <Variable name="x" value="x+50" />
        <Variable name="y" value="y+50" />
        <Text x="var:x" y="var:y" data="text" color="0xFFFFFF" />
    </Frame>
</Window>
