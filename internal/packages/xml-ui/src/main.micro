struct Point {
    x: i64;
    y: i64;
}

export fn main(env) {
    // the elements that we will use
    let window env.xml.XMLUI;
    let rect = env.xml.XMLUI.frame.fill_rect_1;
    let text = env.xml.XMLUI.frame.text_label_1;
    let color = 0xFFFF00FF;

    // set the rect color
    rect.setColor(color)

    // return the environment's condition
    let p: ptr = alloc_struct(Point);
    return env.condition;
}
